# Origin of the leaflet URL-shortener backend (no trailing slash).
# Leave empty to disable shortener integration.
# Example for local dev (run leaflet backend locally):
#   VITE_LEAFLET_API_ORIGIN=http://localhost:3001
# Example for production (self-hosted leaflet instance):
#   VITE_LEAFLET_API_ORIGIN=https://leaflet.lair.nntin.xyz
VITE_LEAFLET_API_ORIGIN=
